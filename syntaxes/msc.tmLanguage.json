{
	"name": "msc",
	"scopeName": "source.msc",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" }
	],
	"repository": {
		"comments": {
			"name": "comment.line.number-sign.msc",
			"begin": "^\\s*#",
			"end": "$"
		},
		"strings": {
			"begin": "\"",
			"end": "\"",
			"beginCaptures": { "0": { "name": "string.quoted.double.msc" } },
			"endCaptures": { "0": { "name": "string.quoted.double.msc" } },
			"patterns": [
				{ "include": "#interpolation" },
				{
					"name": "constant.character.escape.msc",
					"match": "\\\\."
				},
				{
					"name": "string.quoted.double.msc",
					"match": "[^\"\\\\{]+|\\{(?!\\{)"
				}
			]
		},
		"interpolation": {
			"begin": "\\{\\{",
			"end": "\\}\\}"
		}
	}
}
